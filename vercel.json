{
  "installCommand": "node vercel-install.mjs && npm install --legacy-peer-deps",
  "buildCommand": "BASE_PATH=/ PORT=3000 node_modules/.bin/vite build --config artifacts/warehouse-cam/vite.config.ts",
  "outputDirectory": "artifacts/warehouse-cam/dist/public",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index" }
  ],
  "functions": {
    "api/index.ts": {
      "memory": 512,
      "maxDuration": 30
    }
  }
}
